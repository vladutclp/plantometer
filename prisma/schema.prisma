generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PlantType {
  Vegetables
  Fruits
  Grains
  Legumes
  NutsAndSeeds
  HerbsAndSpices
}

model Plant {
  id        Int           @id @default(autoincrement())
  name      String        @unique
  type      PlantType?
  createdAt DateTime      @default(now())
  intakes   PlantIntake[]
}

model PlantIntake {
  id      Int      @id @default(autoincrement())
  plantId Int
  plant   Plant    @relation(fields: [plantId], references: [id])
  date    DateTime @db.Date
}